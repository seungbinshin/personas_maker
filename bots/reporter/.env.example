# Slack credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_USER_ID=U0YOUR_USER_ID

# Required only after changing config.json's llm.provider to "gsapi". It must
# match the reporter entry in gpt-service-api's API_KEYS.
GSAPI_API_KEY=replace-with-the-reporter-gateway-key

# Optional gsapi override when the configured llm object has no URL.
# GSAPI_URL=http://127.0.0.1:8081
