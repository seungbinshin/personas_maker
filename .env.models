# Single source of truth for Claude model pins.
# Sourced by persona.sh at startup and inherited by all bot/API processes.
# To upgrade an entire tier, change the value once here and restart bots.

CLAUDE_OPUS_MODEL=claude-opus-4-7
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# Default when a bot does not pin a specific tier
DEFAULT_CLAUDE_MODEL=$CLAUDE_OPUS_MODEL
